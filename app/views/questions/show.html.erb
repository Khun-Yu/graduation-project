<div class="max-w-3xl mx-auto">
  <!-- Question -->
  <article class="bg-bg-white rounded-xl shadow-sm p-6 mb-6 border border-gray-100">
    <h1 class="text-2xl font-bold text-gray-800 mb-4"><%= @question.title %></h1>
    <div class="flex items-center gap-3 text-xs text-gray-400 mb-4">
      <span class="flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
        <%= @question.user.name %>
      </span>
      <span>|</span>
      <span><%= l(@question.created_at, format: :short) rescue @question.created_at.strftime("%Y/%m/%d %H:%M") %></span>
    </div>
    <div class="text-gray-700 leading-relaxed whitespace-pre-wrap"><%= @question.content %></div>
  </article>

  <!-- AI Answer -->
  <% if @question.ai_answer.present? %>
    <article class="bg-blue-50 border border-blue-200 rounded-xl p-6 mb-4">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-lg">&#x1F916;</span>
        <h2 class="text-lg font-bold text-primary">AI回答</h2>
      </div>
      <div class="text-gray-700 leading-relaxed whitespace-pre-wrap"><%= @question.ai_answer.content %></div>
    </article>

    <!-- Disclaimer -->
    <div class="bg-yellow-50 border border-yellow-300 rounded-lg p-4 text-sm text-yellow-800 flex items-start gap-2 mb-6">
      <span class="shrink-0 mt-0.5">&#x26A0;&#xFE0F;</span>
      <p><strong>免責事項：</strong>この回答はAIによる参考情報です。最終的な判断は、必ず約款・保険会社にご確認ください。</p>
    </div>
  <% end %>

  <!-- Comments Section -->
  <section class="mb-6">
    <div class="flex items-center gap-2 mb-4">
      <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"></path></svg>
      <h2 class="text-lg font-bold text-gray-800">コメント（<%= @question.comments.size %>件）</h2>
    </div>

    <% if @question.comments.any? %>
      <div class="space-y-4">
        <% @question.comments.order(created_at: :asc).each do |comment| %>
          <div class="bg-bg-white border border-gray-100 rounded-lg p-4">
            <div class="flex items-center gap-2 text-xs text-gray-400 mb-2">
              <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                <%= comment.user.name %>
              </span>
              <span>|</span>
              <span><%= l(comment.created_at, format: :short) rescue comment.created_at.strftime("%Y/%m/%d %H:%M") %></span>
            </div>
            <div class="text-gray-700 text-sm leading-relaxed whitespace-pre-wrap"><%= comment.content %></div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-400">まだコメントはありません。AI回答の補足や修正がある場合はコメントしてください。</p>
    <% end %>
  </section>

  <!-- Comment Form -->
  <% if user_signed_in? %>
    <section class="bg-bg-white border border-gray-100 rounded-xl p-6 mb-6">
      <h3 class="text-sm font-bold text-gray-700 mb-3">コメントを投稿する</h3>
      <p class="text-xs text-gray-400 mb-4">AI回答に対する補足・修正・実務経験に基づく情報を共有できます。</p>
      <%= form_with(model: [@question, @comment], class: "space-y-4") do |f| %>
        <div>
          <%= f.text_area :content, placeholder: "コメントを入力してください...", rows: 3, class: "w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition resize-y" %>
        </div>
        <div>
          <%= f.submit "コメントを投稿", class: "bg-primary hover:bg-primary-dark text-white px-6 py-2 rounded-lg text-sm font-semibold transition cursor-pointer" %>
        </div>
      <% end %>
    </section>
  <% else %>
    <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 mb-6 text-center">
      <p class="text-sm text-gray-500 mb-3">コメントを投稿するにはログインが必要です</p>
      <%= link_to "ログイン", new_user_session_path, class: "text-primary hover:underline font-medium text-sm" %>
    </div>
  <% end %>

  <div class="mt-6">
    <%= link_to questions_path, class: "inline-flex items-center gap-1 text-primary hover:underline text-sm font-medium" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
      Q&A一覧に戻る
    <% end %>
  </div>
</div>
