<div class="max-w-3xl mx-auto">
  <!-- Question -->
  <article class="bg-bg-white rounded-xl shadow-sm p-6 mb-6 border border-gray-100">
    <h1 class="text-2xl font-bold text-gray-800 mb-4"><%= @question.title %></h1>
    <div class="flex items-center gap-3 text-xs text-gray-400 mb-4">
      <span class="flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
        <%= @question.user.name %>
      </span>
      <span>|</span>
      <span><%= l(@question.created_at, format: :short) rescue @question.created_at.strftime("%Y/%m/%d %H:%M") %></span>
    </div>
    <div class="text-gray-700 leading-relaxed whitespace-pre-wrap"><%= @question.content %></div>
  </article>

  <!-- AI Answer -->
  <% if @question.ai_answer.present? %>
    <article class="bg-blue-50 border border-blue-200 rounded-xl p-6 mb-4">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-lg">&#x1F916;</span>
        <h2 class="text-lg font-bold text-primary">AI回答</h2>
      </div>
      <div class="text-gray-700 leading-relaxed whitespace-pre-wrap"><%= @question.ai_answer.content %></div>
    </article>

    <!-- Disclaimer -->
    <div class="bg-yellow-50 border border-yellow-300 rounded-lg p-4 text-sm text-yellow-800 flex items-start gap-2">
      <span class="shrink-0 mt-0.5">&#x26A0;&#xFE0F;</span>
      <p><strong>免責事項：</strong>この回答はAIによる参考情報です。最終的な判断は、必ず約款・保険会社にご確認ください。</p>
    </div>
  <% end %>

  <div class="mt-6">
    <%= link_to questions_path, class: "inline-flex items-center gap-1 text-primary hover:underline text-sm font-medium" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
      Q&A一覧に戻る
    <% end %>
  </div>
</div>
