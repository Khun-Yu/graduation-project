<div class="max-w-3xl mx-auto">
  <!-- Question -->
  <article class="bg-bg-white rounded-lg shadow-sm p-6 mb-6">
    <h1 class="text-2xl font-bold text-gray-800 mb-4"><%= @question.title %></h1>
    <div class="text-xs text-gray-400 mb-4">
      投稿者: <%= @question.user.name %> ｜
      <%= l(@question.created_at, format: :short) rescue @question.created_at.strftime("%Y/%m/%d %H:%M") %>
    </div>
    <div class="text-gray-700 leading-relaxed whitespace-pre-wrap"><%= @question.content %></div>
  </article>

  <!-- AI Answer -->
  <% if @question.ai_answer.present? %>
    <article class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-4">
      <h2 class="text-lg font-bold text-primary mb-3">AI回答</h2>
      <div class="text-gray-700 leading-relaxed whitespace-pre-wrap"><%= @question.ai_answer.content %></div>
    </article>

    <!-- Disclaimer -->
    <div class="bg-yellow-50 border border-yellow-300 rounded-md p-4 text-sm text-yellow-800">
      <strong>免責事項：</strong>この回答は参考情報です。最終的な判断は、必ず約款・保険会社にご確認ください。
    </div>
  <% end %>

  <div class="mt-6">
    <%= link_to "← Q&A一覧に戻る", questions_path, class: "text-primary hover:underline text-sm" %>
  </div>
</div>
