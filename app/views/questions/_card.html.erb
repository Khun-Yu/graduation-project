<%= link_to question_path(question), class: "block bg-bg-white rounded-lg shadow-sm p-5 hover:shadow-md transition" do %>
  <h3 class="text-lg font-semibold text-gray-800 mb-2"><%= question.title %></h3>
  <p class="text-gray-600 text-sm mb-3 line-clamp-2"><%= truncate(question.content, length: 120) %></p>
  <div class="flex items-center justify-between text-xs text-gray-400">
    <span><%= question.user.name %></span>
    <span><%= l(question.created_at, format: :short) rescue question.created_at.strftime("%Y/%m/%d %H:%M") %></span>
  </div>
  <% if question.ai_answer.present? %>
    <span class="inline-block mt-2 text-xs bg-green-100 text-green-700 px-2 py-1 rounded">AI回答あり</span>
  <% end %>
<% end %>
