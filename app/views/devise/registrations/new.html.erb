<div class="max-w-md mx-auto">
  <h1 class="text-2xl font-bold text-gray-800 mb-6 text-center">新規登録</h1>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), class: "space-y-5") do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :name, "お名前", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.text_field :name, autofocus: true, class: "w-full border border-gray-300 rounded-md px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
    </div>

    <div>
      <%= f.label :email, "メールアドレス", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.email_field :email, autocomplete: "email", class: "w-full border border-gray-300 rounded-md px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
    </div>

    <div>
      <%= f.label :password, "パスワード", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.password_field :password, autocomplete: "new-password", class: "w-full border border-gray-300 rounded-md px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
      <p class="text-xs text-gray-400 mt-1"><%= @minimum_password_length %>文字以上</p>
    </div>

    <div>
      <%= f.label :password_confirmation, "パスワード（確認）", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full border border-gray-300 rounded-md px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
    </div>

    <div>
      <%= f.submit "アカウントを作成", class: "w-full bg-accent hover:bg-accent-dark text-white py-3 rounded-lg font-semibold transition cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-6 text-center text-sm text-gray-500">
    <p><%= link_to "すでにアカウントをお持ちの方", new_session_path(resource_name), class: "text-primary hover:underline" %></p>
  </div>
</div>
