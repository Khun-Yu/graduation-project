<div class="max-w-md mx-auto">
  <div class="bg-bg-white rounded-xl shadow-lg p-8">
    <h1 class="text-2xl font-bold text-gray-800 mb-2 text-center">ログイン</h1>
    <p class="text-sm text-gray-500 text-center mb-6">アカウントにログインして質問を投稿しましょう</p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), class: "space-y-5") do |f| %>
      <div>
        <%= f.label :email, "メールアドレス", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "example@mail.com", class: "w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition" %>
      </div>

      <div>
        <%= f.label :password, "パスワード", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "current-password", placeholder: "パスワードを入力", class: "w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-2">
          <%= f.check_box :remember_me, class: "rounded text-primary focus:ring-primary" %>
          <%= f.label :remember_me, "ログイン状態を保持する", class: "text-sm text-gray-600" %>
        </div>
      <% end %>

      <div>
        <%= f.submit "ログイン", class: "w-full bg-accent hover:bg-accent-dark text-white py-3 rounded-lg font-semibold transition cursor-pointer shadow-sm hover:shadow-md" %>
      </div>
    <% end %>
  </div>

  <div class="mt-6 text-center text-sm text-gray-500 space-y-2">
    <p><%= link_to "アカウントをお持ちでない方はこちら", new_registration_path(resource_name), class: "text-primary hover:underline font-medium" %></p>
    <p><%= link_to "パスワードを忘れた方", new_password_path(resource_name), class: "text-gray-400 hover:text-primary hover:underline" %></p>
  </div>
</div>
