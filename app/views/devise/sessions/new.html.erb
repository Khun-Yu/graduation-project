<div class="max-w-md mx-auto">
  <h1 class="text-2xl font-bold text-gray-800 mb-6 text-center">ログイン</h1>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), class: "space-y-5") do |f| %>
    <div>
      <%= f.label :email, "メールアドレス", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full border border-gray-300 rounded-md px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
    </div>

    <div>
      <%= f.label :password, "パスワード", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "w-full border border-gray-300 rounded-md px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="flex items-center gap-2">
        <%= f.check_box :remember_me, class: "rounded" %>
        <%= f.label :remember_me, "ログイン状態を保持する", class: "text-sm text-gray-600" %>
      </div>
    <% end %>

    <div>
      <%= f.submit "ログイン", class: "w-full bg-primary hover:bg-primary-dark text-white py-3 rounded-lg font-semibold transition cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-6 text-center text-sm text-gray-500 space-y-2">
    <p><%= link_to "アカウントをお持ちでない方はこちら", new_registration_path(resource_name), class: "text-primary hover:underline" %></p>
    <p><%= link_to "パスワードを忘れた方", new_password_path(resource_name), class: "text-primary hover:underline" %></p>
  </div>
</div>
