<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-800 mb-1">マイページ</h1>
    <p class="text-gray-500 text-sm"><%= current_user.name %> さんの質問履歴</p>
  </div>
  <%= link_to new_question_path, class: "inline-flex items-center gap-1 bg-accent hover:bg-accent-dark text-white px-4 py-2 rounded-lg text-sm font-semibold transition shadow-sm" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
    質問する
  <% end %>
</div>

<% if @questions.any? %>
  <div class="space-y-4">
    <% @questions.each do |question| %>
      <%= render "questions/card", question: question %>
    <% end %>
  </div>

  <div class="mt-8">
    <%= paginate @questions %>
  </div>
<% else %>
  <div class="text-center py-12">
    <div class="text-4xl mb-3">&#x1F4DD;</div>
    <p class="text-gray-500 mb-4">まだ質問を投稿していません。</p>
    <%= link_to "最初の質問を投稿する", new_question_path, class: "inline-block bg-accent hover:bg-accent-dark text-white px-6 py-2 rounded-lg text-sm font-semibold transition" %>
  </div>
<% end %>
